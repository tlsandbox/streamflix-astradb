{
  "name": "streamflix-astra-workshop",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "python3 -m pip install -r backend/requirements.txt && cd frontend && npm install",
  "forwardPorts": [8010, 5174],
  "portsAttributes": {
    "8010": {
      "label": "FastAPI backend"
    },
    "5174": {
      "label": "Vite frontend"
    }
  }
}
