# Astra DB credentials from Astra Portal
ASTRA_DB_API_ENDPOINT=https://<ASTRA_DB_ID>-<REGION>.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:...
ASTRA_DB_KEYSPACE=default_keyspace

# Workshop defaults
DEFAULT_PROFILE_ID=profile_alex
ASTRA_VECTOR_PROVIDER=nvidia
ASTRA_VECTOR_MODEL=NV-Embed-QA

# Maintainer-only snapshot enrichment (optional)
TMDB_API_KEY=
# TMDB_BEARER_TOKEN=

# Frontend/backend local wiring
BACKEND_PORT=8010
FRONTEND_PORT=5174
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
VITE_API_BASE_URL=http://localhost:8010
VITE_DEFAULT_PROFILE_ID=profile_alex
VITE_ASTRA_PORTAL_URL=https://astra.datastax.com/
VITE_GITHUB_REPO_URL=https://github.com/tlsandbox/streamflix-astradb

# Notebook launcher defaults (used by backend /api/admin/notebook)
NOTEBOOK_HOST=127.0.0.1
NOTEBOOK_PORT=8888
NOTEBOOK_RELATIVE_PATH=notebook/streamflix_astra_workshop.ipynb
